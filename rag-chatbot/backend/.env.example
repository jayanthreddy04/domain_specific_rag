# Server
PORT=5001
NODE_ENV=development
LOG_LEVEL=info

# Groq API (https://console.groq.com) — replace with your real key
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Vector storage (pick ONE approach) ---

# Option A: Local JSON store (easiest — no Docker/Chroma account needed)
# Data is saved to ./data/local_vector_store.json after `npm run setup`
USE_LOCAL_VECTOR_STORE=true

# Option B: ChromaDB Docker server (docker compose up -d)
CHROMA_PATH=http://localhost:8000
CHROMA_COLLECTION=ai_knowledge_base

CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=your_chroma_cloud_api_key
CHROMA_TENANT=your_tenant_uuid
CHROMA_DATABASE=your_database_name

# Option C: Chroma Cloud (https://www.trychroma.com)
# Uncomment and fill all three when using cloud:
# CHROMA_HOST=api.trychroma.com
# CHROMA_API_KEY=your_chroma_cloud_api_key
# CHROMA_TENANT=your_tenant_uuid
# CHROMA_DATABASE=your_database_name

# RAG quality thresholds
MIN_RELEVANCE_SCORE=0.32
MIN_QUERY_OVERLAP=0.08

# RAG settings
CHUNK_SIZE=400
CHUNK_OVERLAP=80
RETRIEVAL_TOP_K=12
RERANK_TOP_K=5
HYBRID_ALPHA=0.7

# Embeddings
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# CORS (comma-separated; dev mode also allows any localhost port)
FRONTEND_URL=http://localhost:3000,http://localhost:3001
