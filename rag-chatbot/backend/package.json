{
  "name": "rag-chatbot-backend",
  "version": "1.0.0",
  "description": "Production RAG backend with ChromaDB, Groq, and hybrid retrieval",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "generate-docs": "node scripts/generateDocuments.js",
    "ingest": "node scripts/ingestDocuments.js",
    "evaluate": "node scripts/runEvaluation.js",
    "setup": "npm run generate-docs && npm run ingest"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "chromadb": "^1.9.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "groq-sdk": "^0.8.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
